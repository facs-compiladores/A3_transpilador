programu

nambari a,b,total.
kweli aprovado.
kweli maior.

chapa("===# PROGRAMA DE SOMA #===").
chapa("Digite A").
pembejeo(a).

chapa("Digite B").
pembejeo(b).

total := a + b.

aprovado := kweli.
maior := a > b.

chapa("Resultado:").
chapa(total).

chapa("Status:").
ikiwa aprovado.
chapa("Aprovado").
mwingine.
chapa("Reprovado").

chapa("Maior número:").
ikiwa maior.
chapa("A é maior").
mwingine.
chapa("B é maior").

mwisho.
